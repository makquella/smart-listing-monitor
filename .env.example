APP_NAME=Parset Monitor
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/app.db
ADMIN_READ_ONLY_MODE=false
RUNTIME_MODE=single_process
ALLOW_UNSAFE_MULTI_PROCESS_RUNTIME=false
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BASE_SECONDS=1.0

REQUEST_TIMEOUT_SECONDS=20
PARSER_USER_AGENT=ParsetMonitor/1.0 (+https://example.local)
PARSER_DETAIL_FETCH_WORKERS=12
SCHEDULE_DEFAULT_INTERVAL_MINUTES=60
HEALTH_BASELINE_RUN_WINDOW=5

REMOVAL_MISS_THRESHOLD=2
ALERT_COOLDOWN_HOURS=12
MIN_ABSOLUTE_PRICE_DELTA=1.00
MIN_PERCENT_PRICE_DELTA=2.0
DEGRADED_PARSE_RATIO_THRESHOLD=0.70

BOOKS_SOURCE_NAME=Books to Scrape
BOOKS_SOURCE_SLUG=books-to-scrape
BOOKS_SOURCE_BASE_URL=https://books.toscrape.com/
BOOKS_SOURCE_START_URL=https://books.toscrape.com/catalogue/page-1.html
SEED_ADDITIONAL_DEMO_SOURCES=true
WEBSCRAPER_SOURCE_NAME=Web Scraper Phones
WEBSCRAPER_SOURCE_SLUG=webscraper-phones
WEBSCRAPER_SOURCE_BASE_URL=https://webscraper.io/
WEBSCRAPER_SOURCE_START_URL=https://webscraper.io/test-sites/e-commerce/static/phones

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_CONTROL_ENABLED=false
TELEGRAM_BOT_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_MESSAGE_CHUNK_SIZE=3500
TELEGRAM_RETRY_ATTEMPTS=4
TELEGRAM_RETRY_BASE_SECONDS=1.5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
